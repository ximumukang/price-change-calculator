# ============================================
# 环境变量配置文件模板
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_USERNAME=root
DB_PASSWORD=<your_strong_database_password>

# 数据库 SSL 配置（生产环境建议启用）
# DB_USE_SSL=true
# DB_REQUIRE_SSL=true
# DB_VERIFY_SSL=true

# --------------------------------------------
# JWT 配置
# JWT_SECRET 必须使用至少 256 位（32 字节）的随机密钥
# 生成命令: openssl rand -base64 32
# 示例: kgaYst7T8L15T0Y5oQ+Q/SdJZFXT8Lcm7SXL40RUPJo=
# --------------------------------------------
JWT_SECRET=kgaYst7T8L15T0Y5oQ+Q/SdJZFXT8Lcm7SXL40RUPJo=
JWT_EXPIRATION=7200000

# --------------------------------------------
# RSA 密钥对配置
# Base64 编码的 PKCS#8 私钥和 X.509 公钥
# 可使用 Java KeyPairGenerator 或 OpenSSL 生成
# --------------------------------------------
RSA_PRIVATE_KEY=<your_base64_encoded_private_key>
RSA_PUBLIC_KEY=<your_base64_encoded_public_key>

# --------------------------------------------
# 速率限制配置
# --------------------------------------------
# 登录/注册接口：每分钟允许的请求数（默认 5）
RATE_LIMIT_LOGIN=5
# 通用 API 接口：每分钟允许的请求数（默认 60）
RATE_LIMIT_API=60

# --------------------------------------------
# 账户锁定配置
# --------------------------------------------
# 最大失败次数（默认 5 次）
ACCOUNT_LOCK_MAX_FAILURES=5
# 锁定时长（分钟，默认 15 分钟）
ACCOUNT_LOCK_DURATION=15
